# Copy to .env.local for local dev. Configure on Vercel project settings for prod.

# MongoDB Atlas connection string.
# Atlas → Database → Connect → Drivers → copy URI, replace <password>.
MONGODB_URI="mongodb+srv://USER:PASS@cluster.mongodb.net/?retryWrites=true&w=majority"
MONGODB_DB="logitrack"

# Optional: override API origin. Defaults to same origin + /api.
# VITE_API_BASE_URL="/api"
